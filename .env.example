# Configuración de producción para commerce-crm en el droplet (adapter-node).
# Este archivo es solo de REFERENCIA. El .env real vive en el droplet
# (/root/code/commerce-crm/.env) y NO se commitea (está en .gitignore).
# El GitHub Action hace `source` de ese .env antes de arrancar pm2.

PORT=3100              # puerto local donde escucha la app (nginx hace proxy aquí)
HOST=127.0.0.1         # dirección de bind (solo accesible vía nginx)
DATABASE_URL=./local.db   # ruta del archivo SQLite (relativa al cwd de la app)
ADMIN_PASSWORD=        # contraseña de admin (admin.targetvox.com); vacío = admin deshabilitado

# NOTA: NO usamos ORIGIN. Como el mismo app sirve el apex (targetvox.com) y el
# subdominio admin (admin.targetvox.com), el Action exporta
# PROTOCOL_HEADER=x-forwarded-proto y HOST_HEADER=host para que adapter-node
# derive el origen POR REQUEST (del Host real + X-Forwarded-Proto que manda nginx).
# Fijar ORIGIN rompe el login del subdominio (SvelteKit lo ve como CSRF cross-site).
