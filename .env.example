# Configuración de producción para commerce-crm en el droplet (adapter-node).
# Este archivo es solo de REFERENCIA. El .env real vive en el droplet y NO se commitea
# (está en .gitignore). El GitHub Action exporta estas mismas variables al arrancar pm2.

PORT=3100              # puerto local donde escucha la app (nginx hace proxy aquí)
HOST=127.0.0.1         # solo accesible vía nginx, no expuesto directo
ORIGIN=https://targetvox.com   # clave para cookies "secure" y CSRF detrás de nginx
